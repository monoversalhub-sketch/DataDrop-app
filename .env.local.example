NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (never NEXT_PUBLIC_ for service role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payment Gateway: "monnify" or "flutterwave"
PAYMENT_GATEWAY=monnify
MONNIFY_API_KEY=your-monnify-api-key
MONNIFY_SECRET_KEY=your-monnify-secret-key
MONNIFY_CONTRACT_CODE=your-contract-code
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret
FLUTTERWAVE_HASH=your-flutterwave-webhook-hash

# VTU Providers: "cheapdatahub" or "vtu_ng"
VTU_PROVIDER=cheapdatahub
VTU_API_KEY=your-vtu-api-key
VTU_FALLBACK_PROVIDER=subbase
VTU_FALLBACK_API_KEY=your-fallback-api-key

# WhatsApp Cloud API
WHATSAPP_TOKEN=your-whatsapp-bearer-token
WHATSAPP_PHONE_ID=your-phone-number-id

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Config
VA_EXPIRY_MINUTES=20
